# ===========================================================
# 仓库根 .env 模板:仅供 docker-compose.yml
# 用法:cp .env.example .env
#
# 应用层环境变量分别见:
#   - apps/api/.env.example   (NestJS 后端)
#   - apps/web/.env.example   (Next.js 前端)
# 不再有"根 .env 给 api 用"的共用关系。
# ===========================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bytedance_aigc
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- MinIO ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- 端口冲突说明 ----------
# 如果宿主机已占用 5432 / 6379 / 9000,改这里到空闲端口,
# 同时把 apps/api/.env 里的 DATABASE_URL / REDIS_URL / S3_ENDPOINT 一起更新。

// bytedance-aigc · apps/api · Prisma schema
// Phase 1.1 初始数据建模:User / Draft / DraftVersion
// Phase 1.2 追加 Prompt 库:owner 区分平台 / 私人,9 个 AI 工具枚举锁 DB 层
// 演化路线见 docs/architecture.md §4.1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DraftMode {
  FAST
  FINE
}

enum PromptOwner {
  PLATFORM
  PRIVATE
}

enum DraftStatus {
  DRAFT
  REVIEWING
  PUBLISHED
  OFFLINE
}

enum ReviewStage {
  PREFLIGHT
  PROMPT_INPUT
  SECTION_INLINE
  POST_PUBLISH
}

enum ReviewRecommendation {
  ALLOW
  WARN
  BLOCK
}

enum DraftToolType {
  REWRITE_FLUENT
  EXPAND
  TRANSFORM_STYLE
  HEADLINE_SUB
  HEADLINE_NEW
  REWRITE_OPENING
  ADD_FACTS
  ADD_TOPIC
  IMAGE_SUGGEST
  SAFETY_REVIEW
  QUALITY_REVIEW
  PROMPT_REVIEW
  SECTION_REVIEW
  POST_PUBLISH_REVIEW
  SAFE_REWRITE
  IMAGE_REVIEW
  DATA_DIAGNOSIS
}

enum ReportCategory {
  POLITICS
  PORNOGRAPHY
  GAMBLING
  DRUGS
  VULGARITY
  FRAUD
  MEDICAL
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
}

enum ReportResolution {
  OFFLINE
  WARN
  DISMISS
}

enum SampleAuditStatus {
  PENDING
  PASSED
  FAILED
}

enum RuleRecheckRunStatus {
  RUNNING
  DONE
  FAILED
}

enum AssetReviewStatus {
  PENDING
  PASSED
  WARNED
  BLOCKED
}

model User {
  id           String   @id @default(cuid())
  handle       String   @unique
  phone        String?  @unique
  email        String?  @unique
  passwordHash String?
  role         UserRole @default(AUTHOR)
  createdAt    DateTime @default(now())

  drafts        Draft[]
  prompts       Prompt[] @relation("UserPrompts")
  reports       Report[] @relation("UserReports")
  assets        Asset[]
  notifications Notification[]
  authEvents    AuthEvent[]
  reactions     Reaction[]

  @@map("users")
}

enum UserRole {
  AUTHOR
  ADMIN
}

enum AuthEventType {
  LOGIN
  REGISTER
  LOGOUT
  SEND_CODE
}

model AuthEvent {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      AuthEventType
  method    String?
  identity  String?
  ip        String?
  userAgent String?       @db.Text
  createdAt DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("auth_events")
}

model Asset {
  id          String   @id @default(cuid())
  userId      String
  key         String   @unique
  url         String
  mime        String
  size        Int
  aiGenerated Boolean  @default(false)
  aiPrompt    String?  @db.Text
  sceneTags   String[] @default([])
  subjectTags String[] @default([])
  reviewStatus AssetReviewStatus @default(PENDING)
  reviewNote  String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("assets")
}

model Draft {
  id            String      @id @default(cuid())
  authorId      String
  mode          DraftMode   @default(FAST)
  status        DraftStatus @default(DRAFT)
  title         String
  body              Json
  publishedBody     Json?
  publishedTitle    String?
  publishedVersion  Int?
  version           Int         @default(1)
  publishedAt   DateTime?
  lastReviewId  String?
  offlineReason String?     @db.Text
  offlineAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions   DraftVersion[]
  lastReview Review?        @relation("DraftLastReview", fields: [lastReviewId], references: [id])
  reviews    Review[]       @relation("DraftReviews")
  stat       PostStat?
  reports    Report[]
  reactions  Reaction[]
  sampleAudits SampleAudit[]
  notifications Notification[]

  @@index([authorId])
  @@index([status])
  @@map("drafts")
}

enum VersionKind {
  AUTO
  NAMED
  PUBLISHED
  OFFLINE_CONFLICT
}

model DraftVersion {
  id        String      @id @default(cuid())
  draftId   String
  kind      VersionKind @default(AUTO)
  snapshot  Json
  note      String?     @db.Text
  wordCount Int         @default(0)
  createdAt DateTime    @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([draftId, createdAt])
  @@map("draft_versions")
}

model Prompt {
  id             String        @id @default(cuid())
  owner          PromptOwner
  authorId       String?
  tool           DraftToolType
  name           String
  systemPrompt   String        @db.Text
  params         Json
  fewShots       Json
  designNote     String?       @db.Text
  isStarter      Boolean       @default(false)
  sourcePromptId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  author       User?    @relation("UserPrompts", fields: [authorId], references: [id], onDelete: Cascade)
  sourcePrompt Prompt?  @relation("PromptCopy", fields: [sourcePromptId], references: [id])
  copies       Prompt[] @relation("PromptCopy")
  snapshots    PromptSnapshot[]
  evalRuns     PromptEvalRun[]

  @@index([owner, tool])
  @@index([authorId])
  @@map("prompts")
}

model PromptSnapshot {
  id           String   @id @default(cuid())
  promptId     String
  systemPrompt String   @db.Text
  params       Json
  fewShots     Json
  designNote   String?  @db.Text
  createdAt    DateTime @default(now())

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId, createdAt])
  @@map("prompt_snapshots")
}

model Review {
  id             String               @id @default(cuid())
  draftId        String
  stage          ReviewStage
  safety         Json
  quality        Json
  recommendation ReviewRecommendation
  modelMeta      Json?
  createdAt      DateTime             @default(now())

  draft         Draft   @relation("DraftReviews", fields: [draftId], references: [id], onDelete: Cascade)
  draftLastSeen Draft[] @relation("DraftLastReview")

  @@index([draftId, createdAt(sort: Desc)])
  @@map("reviews")
}

model PostStat {
  id         String   @id @default(cuid())
  draftId    String   @unique
  impression Int      @default(0)
  click      Int      @default(0)
  dwellUnit  Int      @default(0)
  like       Int      @default(0)
  collect    Int      @default(0)
  share      Int      @default(0)
  report     Int      @default(0)
  updatedAt  DateTime @updatedAt

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@map("post_stats")
}

model Report {
  id                String                @id @default(cuid())
  postId            String
  reporterId        String
  category          ReportCategory
  reason            String?               @db.Text
  status            ReportStatus          @default(PENDING)
  resolution        ReportResolution?
  resolverId        String?
  llmRecommendation ReviewRecommendation?
  llmReason         String?               @db.Text
  createdAt         DateTime              @default(now())
  resolvedAt        DateTime?

  post     Draft @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User  @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, postId])
  @@index([postId, status])
  @@index([status, createdAt])
  @@map("reports")
}

enum ReactionKind {
  LIKE
  COLLECT
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  kind      ReactionKind
  createdAt DateTime     @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Draft @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, kind])
  @@index([postId, kind])
  @@map("reactions")
}

model SampleAudit {
  id         String            @id @default(cuid())
  draftId    String
  status     SampleAuditStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?
  note       String?           @db.Text
  createdAt  DateTime          @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([draftId])
  @@map("sample_audits")
}

enum PromptEvalRunStatus {
  RUNNING
  DONE
  FAILED
}

model PromptTestCase {
  id        String        @id @default(cuid())
  tool      DraftToolType
  input     String        @db.Text
  expected  String        @db.Text
  category  String?       @db.Text
  createdAt DateTime      @default(now())

  @@index([tool])
  @@map("prompt_test_cases")
}

model PromptEvalRun {
  id          String               @id @default(cuid())
  tool        DraftToolType
  promptId    String
  totalCases  Int                  @default(0)
  accuracy    Float                @default(0)
  stability   Float                @default(0)
  status      PromptEvalRunStatus  @default(RUNNING)
  startedAt   DateTime             @default(now())
  finishedAt  DateTime?

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([tool, startedAt(sort: Desc)])
  @@map("prompt_eval_runs")
}

model PromptLabAction {
  id           String   @id @default(cuid())
  tool         DraftToolType
  action       String
  fromPromptId String?
  toPromptId   String
  evalRunId    String?
  note         String?  @db.Text
  operatedBy   String
  createdAt    DateTime @default(now())

  @@index([tool, createdAt(sort: Desc)])
  @@map("prompt_lab_actions")
}

enum NotificationType {
  PUBLISH_APPROVED
  PUBLISH_REJECTED
  POST_TAKEN_DOWN
  HOT_RANK
  MILESTONE_VIEWS
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  read      Boolean          @default(false)
  draftId   String?
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft Draft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model RuleRecheckRun {
  id           String                @id @default(cuid())
  ruleVersion  String
  totalScanned Int                   @default(0)
  totalOffline Int                   @default(0)
  status       RuleRecheckRunStatus  @default(RUNNING)
  startedAt    DateTime              @default(now())
  finishedAt   DateTime?

  @@index([status])
  @@map("rule_recheck_runs")
}

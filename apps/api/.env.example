# ===========================================================
# apps/api 运行时环境变量模板
# 用法:cp apps/api/.env.example apps/api/.env,按需修改
# 校验 schema 见 src/config/env.validation.ts;启动期一次性校验,缺失立即拒启动。
# ===========================================================

NODE_ENV=development

# API 监听端口(必填,1-65535)。前端 NEXT_PUBLIC_API_BASE_URL 必须与此一致。
# 默认 4000:刻意避开 Next dev 的 3000。
PORT=4000

# ---------- 数据库(必填) ----------
# 协议必须是 postgresql:// 或 postgres://。本地 docker-compose 默认值如下。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bytedance_aigc

# ---------- Redis(可选) ----------
REDIS_URL=redis://localhost:6379

# ---------- JWT(必填) ----------
# JWT_SECRET 至少 32 字符。生产环境务必换成高熵密钥。
JWT_SECRET=dev-secret-change-me-please-at-least-32-chars
JWT_EXPIRES_IN=7d

# ---------- LLM(必填) ----------
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=deepseek-v4-flash

# ---------- 对象存储 ----------
# STORAGE_DRIVER=mock 时 S3_* 整组可省略(CI / e2e 用)。
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=bytedance-aigc-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/bytedance-aigc-dev
S3_FORCE_PATH_STYLE=true

# ---------- 短信服务 ----------
# SMS_PROVIDER=mock 时走内存固定验证码(开发/CI);volcengine 走火山引擎短信 SDK。
SMS_PROVIDER=mock
# 火山引擎短信 AK/SK(仅 volcengine 模式需要)
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
# 火山引擎短信子账户名(仅 volcengine 模式需要)
SMS_ACCOUNT=
# 已审核通过的短信签名和模板(仅 volcengine 模式需要)
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_REGION=cn-north-1

# ---------- 邮件服务 ----------
# MAIL_PROVIDER=mock 时仅打日志;resend 走 Resend API(个人免费 3000 封/月)。
MAIL_PROVIDER=mock
MAIL_API_KEY=
MAIL_FROM=noreply@example.com

# ---------- 阿里云 AI 安全护栏(必填) ----------
# 审核引擎专用,替代旧 LLM 安全审核。
ALIBABA_CLOUD_ACCESS_KEY_ID=replace-me
ALIBABA_CLOUD_ACCESS_KEY_SECRET=replace-me
GUARD_ENDPOINT=green-cip.cn-shanghai.aliyuncs.com
GUARD_REGION_ID=cn-shanghai

# ---------- 业务开关 ----------
# 二发(已发布稿改回 DRAFT 重新通过审核)时 PostStat 是否保留:
#   true(默认)  → 沿用旧 impression/click/dwell/like(连续阅读体验)
#   false       → 二发后 PostStat 清零(把二发当首发对待)
REPUBLISH_HOTNESS_INHERIT=true
